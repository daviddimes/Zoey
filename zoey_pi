class WakeWordDetector:
    def play_detection_sound(self):
        """Play a gentle, bell-like chime sound when wake word is detected"""
        try:
            # Sound settings
            sample_rate = 44100
            duration = 0.8  # Longer duration for gentler fade
            t = np.linspace(0, duration, int(sample_rate * duration), False)
            
            # Create bell-like frequencies (softer, more ethereal)
            f_root = 392.0  # G4 note - slightly lower base frequency
            f_harmonic1 = f_root * 2.0  # First harmonic
            f_harmonic2 = f_root * 3.0  # Second harmonic
            f_harmonic3 = f_root * 4.0  # Third harmonic
            
            # Generate the harmonics with much lower initial amplitudes
            # Using sine waves with phase offsets for natural sound
            tone1 = 0.3 * np.sin(2 * np.pi * f_root * t)
            tone2 = 0.15 * np.sin(2 * np.pi * f_harmonic1 * t + 0.1)
            tone3 = 0.08 * np.sin(2 * np.pi * f_harmonic2 * t + 0.2)
            tone4 = 0.05 * np.sin(2 * np.pi * f_harmonic3 * t + 0.3)
            
            # Combine tones
            sound = tone1 + tone2 + tone3 + tone4
            
            # Create a very smooth envelope with extremely gentle attack and decay
            attack_time = 0.4  # Even longer attack time (400ms)
            decay_time = 0.4  # Balanced decay time
            attack_samples = int(attack_time * sample_rate)
            decay_samples = int(decay_time * sample_rate)
            
            # Create a smooth envelope curve
            envelope = np.ones_like(t)
            
            # Super gentle attack using a combination of curves for ultra-smooth fade-in
            x = np.linspace(0, 1, attack_samples)
            attack_curve = 0.5 * (1 - np.cos(np.pi * x)) * x**2  # Combined cosine and quadratic
            envelope[:attack_samples] = attack_curve
            
            # Gentle decay using combined exponential curves
            x = np.linspace(0, 1, decay_samples)
            decay_curve = np.exp(-3 * x) * (1 + np.cos(np.pi * x)) * 0.5
            envelope[-decay_samples:] = decay_curve
            
            # Apply envelope
            sound = sound * envelope
            
            # Add very gentle reverb for spaciousness
            reverb_delays = [int(rate * sample_rate) for rate in [0.1, 0.15, 0.2]]
            reverb = np.zeros_like(sound)
            for delay, amplitude in zip(reverb_delays, [0.2, 0.15, 0.1]):  # Reduced reverb amplitudes
                reverb[delay:] += sound[:-delay] * amplitude if delay < len(sound) else 0
            
            # Combine original and reverb with gentle fade
            sound = sound + reverb * envelope  # Apply envelope to reverb too
            
            # Extra gentle normalization and volume adjustment
            sound = sound / np.max(np.abs(sound))  # Normalize
            sound = 0.25 * sound  # Significantly reduce overall volume
            
            # Play the sound using non-blocking playback
            sd.play(sound, sample_rate, blocking=False)
        except Exception as e:
            logger.error(f"Error playing detection sound: {e}")

    def __init__(self, wake_word="zoey", model_path="vosk-model", confidence_threshold=0.05):
        """Initialize the wake word detector
        
        Args:
            wake_word (str): The wake word or phrase to listen for
            model_path (str): Path to the Vosk model directory
            partial_match (bool): If True, allows partial matches of the wake word
            confidence_threshold (float): Required confidence level for wake word detection
        """
        self.exit_flag = False
        self.audio_queue = queue.Queue()
        
        # Audio settings
        self.sample_rate = 16000
        self.channels = 1
        self.block_size = 1024
        self.device_index = self._find_input_device()
        
        # Detection counter
        self.detection_count = 0
        
        # Wake word settings
        self.wake_word = wake_word.lower()
        # Common wake word variations
        self.zoey_variations = {
            'zoey', 'zoe', 'zo', 'joey', 'joe', 'zou', 
            'zoi', 'zoie', 'zowy', 'zoe'
        }
        self.confidence_threshold = confidence_threshold
        self.wake_word_detected = False
        
        # Initialize Vosk model
        try:
            print("Initializing...", end="")
            self.model = Model(model_path)
            self.recognizer = KaldiRecognizer(self.model, self.sample_rate)
            print(" done!")
        except Exception as e:
            logger.error(f"Error initializing Vosk model: {e}")
            sys.exit(1)

    def _find_input_device(self):
        """Find the appropriate audio input device"""
        devices = sd.query_devices()
            
        # Try to find Bluetooth device first
        for i, device in enumerate(devices):
            if ('bluez' in device['name'].lower() and 
                device['max_input_channels'] > 0):
                print(f"\nSelected Bluetooth device: {device['name']}")
                return i
        
        # If no Bluetooth device, use default input device
        default_device = sd.query_devices(kind='input')
        print(f"\nUsing default input device: {default_device['name']}")
        return default_device['index']

    def audio_callback(self, indata, frames, time, status):
        """Callback for audio stream"""
        if status and not status.timeout:
            logger.error(f"Audio error: {status}")
        if not self.exit_flag:
            try:
                # Convert to mono int16 and add to queue immediately
                audio_int16 = (indata * 32767).astype(np.int16)
                if audio_int16.shape[1] > 1:
                    audio_int16 = audio_int16.mean(axis=1).reshape(-1, 1)
                self.audio_queue.put_nowait(audio_int16.copy())
            except Exception as e:
                logger.error(f"Error processing audio: {e}")

    def listen_for_command(self, timeout=10):
        """Listen for user command after wake word detection and process with OpenAI
        
        Args:
            timeout (int): Number of seconds to listen for before timing out
        """
        print("\n🎤 Listening...", end="", flush=True)
        
        start_time = time.time()
        last_partial = ""
        command_text = []
        
        # Clear any old audio data
        while not self.audio_queue.empty():
            self.audio_queue.get()
        
        while time.time() - start_time < timeout:
            try:
                audio_data = self.audio_queue.get(timeout=0.1)
                audio_bytes = bytes(audio_data)
                
                # Show partial results for real-time feedback
                partial = json.loads(self.recognizer.PartialResult())
                partial_text = partial.get("partial", "").strip()
                if partial_text and partial_text != last_partial:
                    print(f"\r🎤 {partial_text}...", end="", flush=True)
                    last_partial = partial_text
                
                # Process complete phrases
                if self.recognizer.AcceptWaveform(audio_bytes):
                    result = json.loads(self.recognizer.Result())
                    text = result.get("text", "").strip()
                    if text:
                        command_text.append(text)
                        print(f"\n✓ {text}")
            
            except queue.Empty:
                continue
            except Exception as e:
                logger.error(f"Error processing command audio: {e}")
        
        print("\n")
        return " ".join(command_text)

    def process_audio(self):
        """Process audio from the queue"""
        last_detection_time = 0
        min_detection_interval = 1.0  # Minimum seconds between detections
        
        while not self.exit_flag:
            try:
                # Get audio data from queue
                audio_data = self.audio_queue.get(timeout=1)
                
                # Convert audio data to bytes for Vosk
                audio_bytes = bytes(audio_data)
                
                # Process audio and check for wake word
                if self.recognizer.AcceptWaveform(audio_bytes):
                    result = json.loads(self.recognizer.Result())
                    text = result.get("text", "").lower()
                    current_time = time.time()
                    
                    if (text and self.check_wake_word(text) and 
                        current_time - last_detection_time >= min_detection_interval):
                        self.detection_count += 1
                        print(f"\n🎯 Hey Zoey detected!")
                        self.wake_word_detected = True
                        last_detection_time = current_time
                        
                        # Play detection sound
                        self.play_detection_sound()
                        
                        # Enter listening mode for command
                        command = self.listen_for_command()
                        if command:
                            print("\n💭 Thinking...", end="", flush=True)
                            response = call_openai(command)
                            print("\n💬 Zoey: " + response)
                            speak_response(response)
                            print("\n📝 Final command:", command)
                
            except queue.Empty:
                continue
            except Exception as e:
                logger.error(f"Error processing audio: {e}")

    def check_wake_word(self, text):
        """Check if the wake word is present in the text
        
        Args:
            text (str): The text to check for wake word
            
        Returns:
            bool: True if wake word is detected, False otherwise
        """
        # Convert to lowercase
        text = text.lower()
        words = text.split()
        
        # Check each word for similarity to our wake words
        for word in words:
            # Direct match with our variations
            if word in self.zoey_variations:
                return True
            
            # Check for common transcription variations
            if 'zo' in word or 'joe' in word:
                return True
            
            # Check for close matches
            if 'zoe' in word or 'zoey' in word:
                return True
        
        return False
    
    def _word_similar(self, word1, word2):
        """Simple word comparison.
        
        Args:
            word1 (str): First word to compare
            word2 (str): Second word to compare
            
        Returns:
            bool: True if words match
        """
        return word1.lower() == word2.lower()

    def signal_handler(self, sig, frame):
        """Handle interrupt signal"""
        print("\nStopping wake word detection...")
        self.exit_flag = True

    def run(self):
        """Start the wake word detection"""
        # Set up signal handler
        signal.signal(signal.SIGINT, self.signal_handler)
        
        try:
            # Start audio processing thread
            process_thread = threading.Thread(target=self.process_audio)
            process_thread.start()
            
            print(f"\nStarting audio stream (device index: {self.device_index})...")
            with sd.InputStream(
                device=self.device_index,
                channels=self.channels,
                samplerate=self.sample_rate,
                blocksize=self.block_size,
                callback=self.audio_callback
            ):
                print("\n👂 Listening for 'Hey Zoey'...")
                while not self.exit_flag:
                    if self.wake_word_detected:
                        # Here you would handle the wake word detection
                        self.wake_word_detected = False
                    time.sleep(0.1)
            
        except Exception as e:
            print(f"Error in audio stream: {e}")
        finally:
            self.exit_flag = True
            process_thread.join()
            print("Wake word detection stopped.")

def main():
    """Main function"""
    # You can customize these settings
    detector = WakeWordDetector(
        wake_word="zoey",
        model_path="vosk-model",
        confidence_threshold=0.1  # Very low threshold for maximum sensitivity
    )
    
    # Print audio device info
    devices = sd.query_devices()
    logger.info("\nAvailable audio devices:")
    for i, device in enumerate(devices):
        logger.info(f"{i}: {device['name']} (in: {device['max_input_channels']}, out: {device['max_output_channels']})")
    
    detector.run()

if __name__ == "__main__":
    main()